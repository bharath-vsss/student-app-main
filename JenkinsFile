pipeline {
    environment {
        AWS_REGION = 'ap-southeast-2'
        ACCOUNT_ID = '510931056289'
        ECR_REPO   = 'devops_repo/app'
        ECR_URL    = "510931056289.dkr.ecr.ap-southeast-2.amazonaws.com/devops_repo/app"
        // We will set APP_VERSION dynamically in the Build stage
    }

    agent any

    stages {
        stage('Checkout') {
            steps {
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: '*/main']],
                    userRemoteConfigs: [[
                        url: 'https://github.com/bharath-vsss/student-app-main.git',
                        credentialsId: 'github_token'
                    ]]
                ])
            }
        }

        stage('Build & Extract Version') {
            steps {
                sh 'mvn clean install'
                // This command extracts the version from pom.xml and removes Maven's info logs
                script {
                    env.APP_VERSION = sh(script: "mvn help:evaluate -Dexpression=project.version -q -DforceStdout", returnStdout: true).trim()
                }
                echo "Detected Version: ${env.APP_VERSION}"
            }
        }

        stage('Test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('Build Docker Image') {
            steps {
                // Using the dynamic version for the local build tag
                sh "docker build -t studentapp:${env.APP_VERSION} ."
            }
        }

        stage('Login to ECR') {
            steps {
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds']]) {
                    sh '''
                        aws ecr get-login-password --region $AWS_REGION | \
                        docker login --username AWS \
                        --password-stdin $ACCOUNT_ID.dkr.ecr.$AWS_REGION.amazonaws.com
                    '''
                }
            }
        }

        stage('Tag & Push to ECR') {
            steps {
                sh """
                    docker tag studentapp:${env.APP_VERSION} $ECR_URL:${env.APP_VERSION}
                    docker tag studentapp:${env.APP_VERSION} $ECR_URL:latest
                    docker push $ECR_URL:${env.APP_VERSION}
                    docker push $ECR_URL:latest
                """
            }
        }
    }
}
