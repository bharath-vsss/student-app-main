pipeline {
    agent any

    parameters {
        string(name: 'AWS_REGION', defaultValue: 'ap-southeast-2', description: 'AWS Region for ECR')
        string(name: 'ECR_REPO_NAME', defaultValue: 'devops_repo/app', description: 'ECR Repository Name')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: '*/main']],
                    userRemoteConfigs: [[
                        url: 'https://github.com/bharath-vsss/student-app-main.git',
                        credentialsId: 'github_token' // Ensure this ID exists in Jenkins Credentials
                    ]]
                ])
            }
        }

        stage('Build & Extract Version') {
            steps {
                sh 'mvn clean install -DskipTests'
                script {
                    // Extract version from pom.xml
                    env.APP_VERSION = sh(script: "mvn help:evaluate -Dexpression=project.version -q -DforceStdout", returnStdout: true).trim()
                }
                echo "Detected Version: ${env.APP_VERSION}"
            }
        }

        stage('Test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh "docker build -t studentapp:${env.APP_VERSION} ."
            }
        }

        stage('Login & Push to ECR') {
            steps {
                // 'aws-creds' should be of type "AWS Credentials" in Jenkins
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds']]) {
                    script {
                        // Dynamically fetch the AWS Account ID based on the credentials used
                        def accountId = sh(script: "aws sts get-caller-identity --query Account --output text", returnStdout: true).trim()
                        def ecrUrl = "${accountId}.dkr.ecr.${params.AWS_REGION}.amazonaws.com"
                        def fullImageUri = "${ecrUrl}/${params.ECR_REPO_NAME}"

                        sh """
                            # Login to ECR
                            aws ecr get-login-password --region ${params.AWS_REGION} | \
                            docker login --username AWS --password-stdin ${ecrUrl}

                            # Tag and Push
                            docker tag studentapp:${env.APP_VERSION} ${fullImageUri}:${env.APP_VERSION}
                            docker tag studentapp:${env.APP_VERSION} ${fullImageUri}:latest
                            
                            docker push ${fullImageUri}:${env.APP_VERSION}
                            docker push ${fullImageUri}:latest
                        """
                    }
                }
            }
        }
    }
    
    post {
        always {
            sh 'docker logout'
            sh "docker rmi studentapp:${env.APP_VERSION} || true"
        }
    }
}
